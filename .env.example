# Archivo de configuración de Entorno

# Si estás ejecutando esto localmente (en tu computadora), renombra este archivo a ".env" 
# y pega aquí la cadena de conexión que te da MongoDB Atlas.

MONGODB_URI=mongodb+srv://tu_usuario:tu_contrasena@clusterX.mongodb.net/AlCineConPapa?retryWrites=true&w=majority

# En Render:
# NO subas el archivo .env
# En su lugar, ve al panel de control de Render > Environment > Environment Variables
# Agrega una variable con nombre MONGODB_URI y pega el valor ahí.
